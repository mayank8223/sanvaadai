{
  "expo": {
    "name": "Sanvaadai Collector",
    "slug": "sanvaadai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "sanvaadai",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sanvaadai.collector",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app uses the microphone for voice-powered form filling."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.sanvaadai.collector",
      "permissions": ["android.permission.RECORD_AUDIO"]
    }
  }
}
